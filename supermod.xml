<?xml version="1.0"?>
<mod
    name="SkinLib"
    description="Library to add Skins"
    author="shinrax2"
    version="0.1.0"
    contact="https://github.com/shinrax2/SkinLib"
    disable_safe_mode="true"
    is_library="true"
    priority="991"
>

    <updates>
		<update provider="modworkshop" identifier="55400"/>
	</updates>

    <hooks>
        <!-- setup classes -->
        <pre hook_id="lib/setups/setup" script_path="hooks/Setup.lua" /> 
        <!-- inject skin data -->
        <post hook_id="lib/managers/weaponfactorymanager" script_path="hooks/WeaponFactoryManager.lua" /> 
        <!-- prevent broken weapons for peers -->
        <post hook_id="lib/units/beings/player/playerinventory" script_path="hooks/PlayerInventory.lua" /> 
        <!-- adds roll rotation on weapon preview -->
        <post hook_id="lib/managers/menu/raid_menu/controls/raidguicontrolrotateunit" script_path="hooks/RaidGUIControlRotateUnit.lua" />
        <!-- hotfix for vanilla crash -->
        <post hook_id="lib/managers/weaponinventorymanager" script_path="hooks/WeaponInventoryManager.lua" />  
        <!-- fix for dp28 crash -->
        <post hook_id="lib/units/weapons/dp28raycastweaponbase" script_path="hooks/DP28RaycastWeaponBase.lua" /> 
        <!-- HUD icon support-->
        <post hook_id="lib/managers/hud/hudweapon/hudweapongrenade" script_path="hooks/HUDWeaponGrenade.lua" /> 
        <post hook_id="lib/managers/hud/hudweapon/hudweapongeneric" script_path="hooks/HUDWeaponGeneric.lua" />
        <post hook_id="lib/managers/menu/raid_menu/weaponselectiongui" script_path="hooks/WeaponSelectionGui.lua" />
    </hooks>

</mod>